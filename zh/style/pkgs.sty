% ------------------------------------------------------------------------------
% TEXT AND FONTS
%
% Font strategy for XeLaTeX / LuaLaTeX:
%   • fontspec          — loads OpenType/TrueType fonts natively
%   • Libertinus-otf    — Libertinus Serif/Sans/Mono text fonts (OTF)
%   • unicode-math      — Unicode math support; use LibertinusMath-Regular.otf
%
% This combination avoids ALL of the following known issues:
%   ✗ "Can't use xelatex/lualatex" — caused by libertinus-type1 (pdfLaTeX only)
%   ✗ "Missing character … in font cmr" — OTF fonts are natively supported
%   ✗ "Command \eth already defined"   — unicode-math replaces amssymb cleanly
%
% Load order (MUST be followed):
%   1. amsthm                        (before any math font — prevents \openbox conflict)
%   2. mathtools                     (MUST precede unicode-math; unicode-math overwrites
%                                    \dblcolon, \coloneqq, \Coloneqq, \eqqcolon)
%   3. \PassOptionsToPackage{…}{unicode-math}  (MUST precede libertinus-otf)
%   4. libertinus-otf                (loads fontspec + unicode-math + setmathfont internally)
%   5. siunitx                       (units — must come after math packages)


% ---- 1. Theorem environments (must precede math fonts) ----------------------
\usepackage{amsthm}


% ---- 2. Font loader (XeLaTeX/LuaLaTeX native) -------------------------------
\usepackage{fontspec}

% ---- 3. Math tools — loaded BEFORE libertinus-otf ----------------------------
% mathtools must precede unicode-math so that amsmath/mathtools definitions
% are in place before unicode-math tries to overwrite \dblcolon, \coloneqq,
% \Coloneqq, \eqqcolon.  unicode-math will overwrite these — that is intentional.
% amsthm is already loaded (line 36) before this section, so no \openbox conflict.
\usepackage{mathtools}             % extends amsmath; loaded before unicode-math

% ---- 4. Math fonts (Libertinus OTF) ------------------------------------------
% libertinus-otf internally loads unicode-math and calls \setmathfont.
% Passing unicode-math options via \PassOptionsToPackage BEFORE loading
% libertinus-otf avoids the "Option clash for package unicode-math" error.
% Do NOT load \usepackage{unicode-math} separately — libertinus-otf handles it.
%
% \symbf is unicode-math's correct bold math command (uses Mathematical Bold
% Unicode block, rendered from LibertinusMath). We redefine \mathbf to use it
% so that \mathbf{\Sigma}/\mathbf{\theta} route through the math font rather
% than LibertinusSerif-Bold.
% Wrapping in \mathord prevents LaTeX3 group markers (\__um_group_begin:) from
% leaking into subscript contexts (e.g. _\mathbf{y}), which previously caused
% "Missing {" and "can't use \eqno" errors.
\PassOptionsToPackage{math-style=ISO, bold-style=ISO}{unicode-math}
\usepackage{libertinus-otf}

% ---- 4b. Bold math (bm — NOT compatible with unicode-math in XeLaTeX) -------
% Note: bm is NOT loaded for XeLaTeX as it conflicts with unicode-math.
% Bold Greek letters will render in their regular upright form.

% ---- 5. Monospace -----------------------------------------------------------
\usepackage[scale=0.85]{plex-mono}

% ---- 6. Additional math tools -----------------------------------------------
\usepackage[separate-uncertainty=true]{siunitx}

