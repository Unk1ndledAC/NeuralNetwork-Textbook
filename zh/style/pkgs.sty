    \begin{itemize}%
}{%
    \end{itemize}%
    \end{tcolorbox}%
}

\newenvironment{disadvantages}{%
    \begin{tcolorbox}[enhanced,colback=red-50,colframe=activation-red,fonttitle=\bfseries,title=缺点,arc=1mm,boxrule=0.5pt,left=4pt,right=4pt,top=2pt,bottom=2pt]%
    \begin{itemize}%
}{%
    \end{itemize}%
    \end{tcolorbox}%
}
