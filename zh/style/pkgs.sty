% CUSTOM ENVIRONMENTS (Chinese)
% 定理类环境
\newtheorem{theorem}{定理}[chapter]
\newtheorem{definition}{定义}[chapter]
\newtheorem{example}{示例}[chapter]

% theorem 的中文别名
\newenvironment{定理}[1][]{\begin{theorem}[#1]}{\end{theorem}}
% definition 的中文别名
\newenvironment{定义}[1][]{\begin{definition}[#1]}{\end{definition}}
% example 的中文别名（与英文 example 共享计数器）
\newenvironment{示例}[1][]{\begin{example}[#1]}{\end{example}}

% 非定理类环境（使用 tcolorbox 风格的简单实现）
\usepackage[most]{tcolorbox}

\newtcolorbox{properties}[1][]{
    enhanced,
    colback=blue-50,
    colframe=blue-300,
    fonttitle=\bfseries,
    title={#1},
    arc=1mm,
    boxrule=0.5pt,
    left=4pt, right=4pt, top=2pt, bottom=2pt,
}

\newtcolorbox{architecture}[1][]{
    enhanced,
    colback=gray-50,
    colframe=gray-400,
    fonttitle=\bfseries,
    title={#1},
    arc=1mm,
    boxrule=0.5pt,
    left=4pt, right=4pt, top=2pt, bottom=2pt,
}

\newtcolorbox{note}[1][]{
    enhanced,
    colback=green-50,
    colframe=green-300,
    fonttitle=\bfseries,
    title={#1},
    arc=1mm,
    boxrule=0.5pt,
    left=4pt, right=4pt, top=2pt, bottom=2pt,
}

% properties 的中文别名
\newenvironment{性质}[1][]{\begin{properties}[#1]}{\end{properties}}

% 证明环境
\newtcolorbox{proofbox}[1][证明]{
    enhanced,
    colback=blue-50,
    colframe=blue-500,
    fonttitle=\bfseries,
    title={#1},
    arc=1mm,
    boxrule=0.5pt,
    left=4pt, right=4pt, top=2pt, bottom=2pt,
}
\newenvironment{证明}[1][]{\begin{proofbox}[#1]}{\end{proofbox}}

% 问题环境
\newtcolorbox{problembox}[1][]{
    enhanced,
    colback=orange-50,
    colframe=activation-orange,
    fonttitle=\bfseries,
    title={#1},
    arc=1mm,
    boxrule=0.5pt,
    left=4pt, right=4pt, top=2pt, bottom=2pt,
}
\newenvironment{问题}[1][]{\begin{problembox}[#1]}{\end{problembox}}

