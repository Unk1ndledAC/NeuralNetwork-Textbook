% ------------------------------------------------------------------------------
% Import the packages and definitions

% Use XeLaTeX package set
\usepackage{style/pkgs}
\usepackage{style/colors}


% ------------------------------------------------------------------------------
% PDF PARAMETERS
% These commands are only available under pdfLaTeX; guard them accordingly.

\ifdefined\pdfminorversion
  \pdfminorversion=7
\fi
\ifdefined\pdfinclusioncopyfonts
  \pdfinclusioncopyfonts=1
\fi
\ifdefined\pdfgentounicode
  \pdfgentounicode=1
\fi


% ------------------------------------------------------------------------------
% TEXT STYLE

\setlength{\parindent}{5mm}  % Indentation
\setlength{\parskip}{1mm}  % Paragraph skip

% Default spacing between lines (必须在 \begin{document} 之后执行)
\AtBeginDocument{%
    \renewcommand*\baselinestretch{1.06}\selectfont % 1.06 for Libertinus Serif
}%

% Commands to have small monospace text
\NewCommandCopy{\svtt}{\texttt}
\DeclareRobustCommand*\texttt[1]{\svtt{\small#1}}

% No skip between items in a list to save space
\setenumerate{itemsep=0mm}
\setitemize{itemsep=0mm}
\setdescription{itemsep=0mm}


% ------------------------------------------------------------------------------
% STYLE OF TITLES

% Chapter
\titleformat{\chapter}[display]
{}
{\large\scshape\chaptername\enspace\thechapter}
{0mm}
{\LARGE\bfseries}
[]

\titlespacing{\chapter}{0mm}{-5mm}{5mm}
\titlespacing{\section}{0mm}{3mm}{1mm}
\titlespacing{\subsection}{0mm}{3mm}{1mm}
\titlespacing{\subsubsection}{0mm}{3mm}{1mm}


% ------------------------------------------------------------------------------
% TABLE OF CONTENTS

\setcounter{tocdepth}{4}
\setcounter{secnumdepth}{4}

% Column separation - multicol
\setlength{\columnsep}{8mm}


% ------------------------------------------------------------------------------
% HYPERREF SETUP

\hypersetup{%
    pdfborder = {0 0 0},
    unicode = true,  % allows to use characters of non-Latin based languages
    bookmarksnumbered = true,
    pdfstartview = {FitH},
    pdfpagemode = UseOutlines,
    pdftitle = {\thesisTitle},  % title
    pdfauthor = {\thesisAuthor},  % authors
    %pdfsubject = {\thesisType - \thesisTitle},  % subject of the document
    pdfkeywords = {\thesisKeywords},  % list of keywords
    pdfinfo={%
        Title={\thesisTitle},
        Author={\thesisAuthor}
    },
    colorlinks = true,  % false: boxed links; true: colored, boxed links
    linkcolor = url-color,  % color of internal links (blue)
    citecolor = cite-color,  % color of links to bibliography (green)
    filecolor = file-color,  % color of file links (black)
    urlcolor = url-color,  % color of external links (green)
}

% The color of glossary cites is black for easier reading
\DeclareRobustCommand*{\glstextformat}[1]{\textcolor{black}{#1}}


% ------------------------------------------------------------------------------
% CODE LISTINGS - LISTINGS

\lstset{
    backgroundcolor=\color{listing-background},
    basicstyle=\ttfamily\footnotesize,
    breaklines=true,
    tabsize=4,
    numbers=left,
    numberstyle=\tiny\color{gray-500},
    frame=single,
    rulecolor=\color{gray-300},
    captionpos=b,
    escapeinside={(*@}{@*)},
    showstringspaces=false,
}

\newenvironment{code}{\captionsetup{type=lstlisting}}{}


% ------------------------------------------------------------------------------
% FIGURES AND CAPTIONS

% fix autoref for subfloats
\DeclareRobustCommand*\subfigureautorefname{\figureautorefname}

% Spacing

\setlength{\abovedisplayskip}{2mm}  % space above captions
\setlength{\belowdisplayskip}{2mm}  % space below captions
\setlength{\abovedisplayshortskip}{0mm}  % space above captions
\setlength{\belowdisplayshortskip}{0mm}  % space below captions
\setlength{\intextsep}{5mm}  % top/bottom space between in-text floats
\setlength{\floatsep}{5mm}  % top/bottom space between adjacent floats
\setlength{\textfloatsep}{5mm}  % top/bottom space between text and floats

% Table types

% New 'M' style for tables that centers text vertically and horizontally.
\newcolumntype{M}[1]{>{\centering\arraybackslash}m{#1}}
% New 'R' style for tables that centers text vertically and to the right
\newcolumntype{R}[1]{>{\raggedleft\arraybackslash}m{#1}}
% New 'L' style for tables that centers text vertically and to the left
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}m{#1}}


\let\oldquote\quote \DeclareRobustCommand*\quote{\oldquote\sf\itshape}
\let\oldquote\quotation \DeclareRobustCommand*\quotation{\oldquote\sf}


% ------------------------------------------------------------------------------
%% ICONS

% Command to vertically centre adjacent content
\DeclareRobustCommand*\vcenteredhbox[1]
{%
    \noindent\setbox0=\hbox{#1}\parbox{\wd0}{\box0}%
}

% 1: FontAwesome icon command, e.g.: "\faLinkedIn"
% 2: box size (in pt), e.g.: "12"
% 3: color, e.g.: "blue"
\DeclareRobustCommand*\icon[3]
{%
    \vcenteredhbox{%
        \colorbox{#3}{%
            \renewcommand*\arraystretch{0.8}\tabular{#3}
                \renewcommand*\arraystretch{1.0}
                \textcolor{white}{\noindent #1}%
            \endtabular
        }%
    }%
}


% ------------------------------------------------------------------------------
% PAGE STYLE AND GEOMETRY
%
% 正16开纸张尺寸：185mm × 260mm
% 这是中文书籍常用开本，适合印刷

\geometry{
    papersize = {185mm, 260mm},
    top     = 2.5cm,
    bottom  = 2.5cm,
    inner   = 2.5cm,
    outer   = 2.0cm
}
\setlength{\headheight}{13.6pt}

% Chapters

\fancypagestyle{chapters}
{
    \fancyhfoffset[RO,LE]{0cm}

    \fancyhead[LE]{\sf\small{\thepage}}
    \fancyhead[RE]{\sf\small{\nouppercase{\leftmark}}}
    \fancyhead[C]{}
    \fancyhead[LO]{\sf\small{\nouppercase{\rightmark}}}
    \fancyhead[RO]{\sf\small{\thepage}}

    \fancyfoot[LE]{\sf\small{\thepage}}
    \fancyfoot[RE]{\sf\small{\thesisTitleShort}}
    \fancyfoot[C]{}
    \fancyfoot[LO]{\sf\small{\thesisAuthor}}
    \fancyfoot[RO]{\sf\small{\thepage}}

    \renewcommand*\headrulewidth{0.1mm}
    \renewcommand*\footrulewidth{0.1mm}
}

% Addendum

\fancypagestyle{addenda}
{
    \fancyhfoffset[RO,LE]{0cm}

    \fancyhead[LE]{\sf\small{\thepage}}
    \fancyhead[RE]{\sf\small{\nouppercase{\leftmark}}}
    \fancyhead[C]{}
    \fancyhead[LO]{\sf\small{\nouppercase{\rightmark}}}
    \fancyhead[RO]{\sf\small{\thepage}}

    \fancyfoot[LE]{\sf\small{\thepage}}
    \fancyfoot[RE]{\sf\small{\thesisTitleShort}}
    \fancyfoot[C]{}
    \fancyfoot[LO]{\sf\small{\thesisAuthor}}
    \fancyfoot[RO]{\sf\small{\thepage}}

    \renewcommand*\headrulewidth{0.1mm}
    \renewcommand*\footrulewidth{0.1mm}
}

% Plain

\fancypagestyle{plain}
{
    \fancyhfoffset[RO,LE]{0cm}

    \fancyhead[LE]{}
    \fancyhead[RE]{}
    \fancyhead[C]{}
    \fancyhead[LO]{}
    \fancyhead[RO]{\sf\small{\thepage}}

    \fancyfoot[LE]{\sf\small{\thepage}}
    \fancyfoot[RE]{}
    \fancyfoot[C]{}
    \fancyfoot[LO]{}
    \fancyfoot[RO]{\sf\small{\thepage}}

    \renewcommand*\headrulewidth{0.0mm}
    \renewcommand*\footrulewidth{0.0mm}
}




% Empty

\fancypagestyle{empty}
{
    \fancyhf{}
    \fancyhead{}

    \fancyhead[LE]{}
    \fancyhead[RE]{}
    \fancyhead[C]{}
    \fancyhead[LO]{}
    \fancyhead[RO]{}

    \fancyfoot[LE]{}
    \fancyfoot[RE]{}
    \fancyfoot[C]{}
    \fancyfoot[LO]{}
    \fancyfoot[RO]{}

    \renewcommand*\headrulewidth{0mm}
    \renewcommand*\footrulewidth{0mm}
}


% Bibliography

\fancypagestyle{biblio}
{
    \fancyhfoffset[RO,LE]{0cm}

    \fancyhead[LE]{\sf\small{\thepage}}
    \fancyhead[RE]{\sf\small{\nouppercase{\leftmark}}}
    \fancyhead[C]{}
    \fancyhead[LO]{\sf\small{\nouppercase{\rightmark}}}
    \fancyhead[RO]{\sf\small{\thepage}}

    \fancyfoot[LE]{\sf\small{\thepage}}
    \fancyfoot[RE]{\sf\small{\thesisTitleShort}}
    \fancyfoot[C]{}
    \fancyfoot[LO]{\sf\small{\thesisAuthor}}
    \fancyfoot[RO]{\sf\small{\thepage}}

    \renewcommand*\headrulewidth{0.2mm}
    \renewcommand*\footrulewidth{0.2mm}
}


% ------------------------------------------------------------------------------
% Really blank pages between chapters

\let\origdoublepage\cleardoublepage
\DeclareRobustCommand*\clearemptydoublepage{%
  \clearpage
  {\pagestyle{plain}\origdoublepage}%
}

\let\cleardoublepage\clearemptydoublepage
