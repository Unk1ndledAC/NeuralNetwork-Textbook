{
    // ─────────────────────────────────────────────────────────────────────────
    // LaTeX Workshop – Project-level overrides
    //
    // Compiler : XeLaTeX  (required for fontspec / libertinus-otf / unicode-math)
    // Bib tool : Biber    (required for biblatex; NOT bibtex)
    // Full build: xelatex → biber → xelatex → xelatex
    // ─────────────────────────────────────────────────────────────────────────

    // Always use this recipe by default for this project (not "lastUsed")
    "latex-workshop.latex.recipe.default": "xelatex -> biber -> xelatex (biblatex)",

    // Root file: always compile main.tex regardless of which file is open
    "latex-workshop.latex.rootFile.useSubFileAsRoot": false,

    // Auto-build on file save
    "latex-workshop.latex.autoBuild.run": "onFileChange",

    // NEVER auto-clean intermediate files for this project.
    // Cleaning .toc/.lof/.bbl/.bcf etc. breaks multi-pass compilation.
    // Use "Clean up auxiliary files" command manually if needed.
    "latex-workshop.latex.autoClean.run": "never",

    // Show errors/warnings in VSCode Problems panel
    "latex-workshop.message.error.show": true,
    "latex-workshop.message.warning.show": true,

    // SyncTeX: double-click in PDF to jump to source
    "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
    "latex-workshop.synctex.afterBuild.enabled": true
}
